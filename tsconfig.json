


{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    //"moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["api/**/*", "lib/**/*"],
  "exclude": ["node_modules", "dist", "frontend"]
}
